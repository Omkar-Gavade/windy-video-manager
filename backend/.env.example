# --- AWS / S3 configuration ---
# Region MUST match the bucket's region (required for valid presigned URLs).
AWS_REGION=us-east-1
S3_BUCKET=your-private-video-bucket
S3_PREFIX=videos/

# --- AWS credentials ---
# Leave these to the standard boto3 provider chain.
# Local dev: set them in your shell / ~/.aws/credentials.
# Production: use an IAM role. Do NOT commit real keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Upload constraints ---
MAX_UPLOAD_MB=200
ALLOWED_VIDEO_MIME=video/mp4,video/webm,video/quicktime

# --- Presigned URL expiry (seconds) ---
PREVIEW_EXPIRY_SECONDS=300
DOWNLOAD_EXPIRY_SECONDS=600

# --- CORS (comma-separated frontend origins) ---
ALLOWED_ORIGINS=http://localhost:5173
