# ==========================================================================
# Backend configuration — copy to backend/.env and fill in.
# GITIGNORED. Never commit real credentials. No secrets are baked into images.
# ==========================================================================

# --- AWS / S3 (REQUIRED) ---------------------------------------------------
# Region MUST match the bucket's region (required for valid presigned URLs).
AWS_REGION=ap-south-1
S3_BUCKET=your-private-bucket-name

# Object-key prefixes for each module (defaults shown).
S3_PREFIX=videos/
INPUTS_PREFIX=inputs/

# --- AWS credentials -------------------------------------------------------
# Resolved by the standard boto3 provider chain.
#   Local/dev  : set these here, or in the shell / ~/.aws/credentials.
#   Production : attach an IAM role to the instance and OMIT these keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Upload constraints ----------------------------------------------------
MAX_UPLOAD_MB=200
ALLOWED_VIDEO_MIME=video/mp4,video/webm,video/quicktime

# Inputs — per-category extension allowlists (defaults shown).
ALLOWED_DATA_EXTENSIONS=.csv,.txt,.json,.xlsx,.xls,.pdf,.dat
ALLOWED_INPUT_VIDEO_EXTENSIONS=.mp4,.webm,.mov
ALLOWED_INPUT_IMAGE_EXTENSIONS=.png,.jpg,.jpeg,.gif,.webp,.bmp

# --- Presigned URL expiry (seconds) ----------------------------------------
PREVIEW_EXPIRY_SECONDS=300
DOWNLOAD_EXPIRY_SECONDS=600

# --- CORS ------------------------------------------------------------------
# Only matters if the API is called cross-origin. In the Docker deployment the
# frontend nginx proxies /api same-origin, so CORS is not exercised.
ALLOWED_ORIGINS=http://localhost:5173
